{
  "name": "whisker-protocol",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:playables": "PLAYABLES=true vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-transform-types --disable-warning=ExperimentalWarning --import=./scripts/test-alias-loader.mjs --test 'src/**/*.test.ts'"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  }
}
